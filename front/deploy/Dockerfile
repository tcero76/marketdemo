FROM node:20-slim AS base
WORKDIR /app
COPY package*.json ./
COPY tsconfig.json ./
COPY next.config.ts ./

FROM base AS dev
RUN npm install
COPY . .
EXPOSE 3000
CMD npm run dev

FROM base AS builder

ARG NEXT_PUBLIC_HOST
ARG NEXT_PUBLIC_WS
ARG NEXT_PUBLIC_HYDRA
ARG NEXT_PUBLIC_CLIENT_ID
ARG NEXT_PUBLIC_MOCK
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ARG NEXT_PUBLIC_HOME_PAGE_PATH

ENV NEXT_PUBLIC_HOST=$NEXT_PUBLIC_HOST
ENV NEXT_PUBLIC_WS=$NEXT_PUBLIC_WS
ENV NEXT_PUBLIC_HYDRA=$NEXT_PUBLIC_HYDRA
ENV NEXT_PUBLIC_CLIENT_ID=$NEXT_PUBLIC_CLIENT_ID
ENV NEXT_PUBLIC_MOCK=$NEXT_PUBLIC_MOCK
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_HOME_PAGE_PATH=$NEXT_PUBLIC_HOME_PAGE_PATH

RUN npm ci
COPY . .
RUN npm run build

FROM node:20-alpine AS prod
WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.ts ./next.config.ts

USER node
EXPOSE 3000
CMD npm run start
